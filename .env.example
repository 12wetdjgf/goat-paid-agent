# GOAT x402 merchant credentials
GOATX402_MERCHANT_ID=your_merchant_id_here
GOATX402_API_URL=https://api.x402.goat.network
GOATX402_API_KEY=your_api_key_here
GOATX402_API_SECRET=your_api_secret_here

# App server port
PORT=3001

# Optional AI provider, OpenAI-compatible API
AI_BASE_URL=https://api.openai.com/v1
AI_API_KEY=your_ai_api_key_here
AI_MODEL=gpt-4.1-mini

# Optional public URL used in docs/metadata
PUBLIC_APP_URL=http://localhost:3000
